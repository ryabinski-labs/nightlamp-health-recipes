{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GipsyChef/nightlamp-health-recipes/schemas/recipe.schema.json",
  "title": "Nightlamp Health Recipe",
  "description": "Machine-readable manifest for a scenario-specific health-check recipe.",
  "type": "object",
  "required": [
    "id",
    "scenario",
    "audience",
    "symptoms",
    "failure_modes",
    "checks",
    "expected_signals",
    "triage",
    "alert_routing",
    "references",
    "last_reviewed",
    "owner"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Kebab-case scenario slug; must match the recipe directory name.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 64
    },
    "scenario": {
      "type": "string",
      "description": "One short sentence describing the failure this recipe covers.",
      "minLength": 8,
      "maxLength": 200
    },
    "audience": {
      "type": "array",
      "description": "Which kinds of app operators this recipe is for.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "bubble",
          "lovable",
          "cursor",
          "webflow",
          "flutterflow",
          "no-code",
          "ai-built",
          "generic"
        ]
      },
      "uniqueItems": true
    },
    "symptoms": {
      "type": "array",
      "description": "Customer-visible symptoms when this failure occurs.",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "failure_modes": {
      "type": "array",
      "description": "Underlying causes that produce the symptoms.",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "checks": {
      "type": "array",
      "description": "Monitor definitions using the generic Nightlamp taxonomy.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "expected_signals": {
      "type": "object",
      "description": "What a passing vs failing run looks like.",
      "required": ["pass", "fail"],
      "additionalProperties": false,
      "properties": {
        "pass": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "fail": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "false_positives": {
      "type": "array",
      "description": "Known reasons the recipe might fire when nothing is actually broken.",
      "items": { "type": "string" }
    },
    "triage": {
      "type": "array",
      "description": "Ordered checklist a human can follow during an incident.",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "alert_routing": {
      "type": "object",
      "description": "Who to wake, how loudly, and when to suppress.",
      "required": ["severity", "channel"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["page", "ticket", "digest"]
        },
        "channel": { "type": "string", "minLength": 2 },
        "suppress_when": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Canonical links: vendor docs, Nightlamp guides, community threads.",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "last_reviewed": {
      "type": "string",
      "description": "ISO date the recipe was last verified end-to-end.",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "owner": {
      "type": "string",
      "description": "Maintainer handle/team responsible for this recipe.",
      "minLength": 2
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["type", "name"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "http_status",
            "http_keyword",
            "ssl",
            "tcp",
            "api_canary",
            "browser_journey",
            "visual_snapshot",
            "heartbeat"
          ]
        },
        "name": { "type": "string", "minLength": 3, "maxLength": 120 },
        "cadence_seconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 86400
        },
        "target": { "type": "string" },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH"]
        },
        "assert_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "assert_keyword": { "type": "string" },
        "assert_keyword_absent": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "type": "object" }
        },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "days_before_expiry": { "type": "integer", "minimum": 1, "maximum": 365 },
        "diff_threshold_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "viewport": { "type": "string" },
        "expected_interval_seconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 604800
        },
        "notes": { "type": "string" }
      }
    }
  }
}
